# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001

# URL where THIS backend is running (used for verification email links)
WEBSITE_URL=http://localhost:3001

# URL of the Next.js tool/app after login (e.g. http://localhost:3000)
APP_URL=http://localhost:3000

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# From Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# From Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# From Stripe dashboard → Products → Prices (create two recurring products)
STRIPE_PRICE_PRO=price_...       # £20/month
STRIPE_PRICE_STUDENT=price_...   # £15/month

# ─── RESEND (email) ──────────────────────────────────────────────────────────
# From resend.com → API Keys
# Used to send student verification emails
RESEND_API_KEY=re_...

# ─── GITHUB OAUTH (optional) ─────────────────────────────────────────────────
# Only needed if using custom GitHub OAuth (not Supabase's built-in OAuth)
GITHUB_CLIENT_ID=Ov23...
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (leave empty to allow all in development)
CORS_ORIGIN=http://localhost:3001,https://yourdomain.com
