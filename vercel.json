{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "website/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*\\.(html|css|js|json|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf))", "dest": "website/$1" },
    { "src": "/(.*)", "dest": "website/$1.html" },
    { "src": "/", "dest": "website/index.html" }
  ]
}
